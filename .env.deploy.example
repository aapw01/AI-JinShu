# --------------------------------------------------------------------
# Deployment image
# --------------------------------------------------------------------
# 必填：要部署的单镜像名称。默认示例使用 GHCR 发布产物。
# 该镜像内同时包含 api、web、worker、beat，由 supervisord 管理。
APP_IMAGE=ghcr.io/aapw01/ai-jinshu:latest

# 可选：对外暴露端口。留默认即可。
API_PORT=8000
WEB_PORT=3000

# --------------------------------------------------------------------
# Runtime mode
# --------------------------------------------------------------------
# 枚举：development | test | production
# 部署环境建议固定为 production。
ENV=production

# --------------------------------------------------------------------
# PostgreSQL container bootstrap
# --------------------------------------------------------------------
# 必填：给 postgres 容器初始化使用，也要与 DATABASE_URL 保持一致。
POSTGRES_USER=novel
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=novel_db

# --------------------------------------------------------------------
# Database / Redis / Celery
# --------------------------------------------------------------------
# 必填：应用实际使用的数据库连接。
DATABASE_URL=postgresql://novel:change-me-in-production@postgres:5432/novel_db
# 可选：应用容器启动前自动执行 alembic upgrade head。
AUTO_MIGRATE_ON_START=true
# 必填：Redis 连接。
REDIS_URL=redis://redis:6379/0
# 必填：Celery broker 连接。
CELERY_BROKER_URL=redis://redis:6379/1

# --------------------------------------------------------------------
# LLM / Embedding
# --------------------------------------------------------------------
# 必填：主模型 provider。
# 枚举：openai | anthropic | gemini
LLM_PROVIDER=openai
# 必填：主聊天模型名称。
LLM_MODEL=gpt-4o-mini
# 可选：自定义网关地址。留空使用 provider 默认端点。
LLM_BASE_URL=
# 必填：主模型 API Key。
LLM_API_KEY=your-api-key-here
# 可选：强制指定协议。留空即 auto。
# 枚举：openai_compatible | anthropic | gemini
LLM_PROTOCOL_OVERRIDE=

# 可选：是否启用向量模型。
# 枚举：true | false
EMBEDDING_ENABLED=true
# 可选：向量模型名称。
EMBEDDING_MODEL=text-embedding-3-small
# 可选：是否复用主模型连接，仅对 OpenAI 兼容协议有效。
# 枚举：true | false
EMBEDDING_REUSE_PRIMARY_CONNECTION=true
# 可选：独立向量模型网关地址。
EMBEDDING_BASE_URL=
# 可选：独立向量模型 API Key。
EMBEDDING_API_KEY=

# --------------------------------------------------------------------
# Auth
# --------------------------------------------------------------------
# 必填：生产环境必须替换为 32 位以上强随机密钥。
AUTH_JWT_SECRET=change-me-in-production-and-must-be-at-least-32-bytes
# 可选：JWT issuer。
AUTH_JWT_ISSUER=ai-jinshu
# 可选：访问令牌分钟数。
AUTH_ACCESS_TOKEN_MINUTES=15
# 可选：生产环境建议 true。
# 枚举：true | false
AUTH_COOKIE_SECURE=true
# 可选：Cookie 作用域域名。
AUTH_COOKIE_DOMAIN=
# 可选：是否强制邮箱激活。
# 枚举：true | false
AUTH_REQUIRE_EMAIL_VERIFICATION=false
# 可选：登录失败锁定阈值。
AUTH_LOGIN_MAX_FAILURES=5
# 可选：登录锁定分钟数。
AUTH_LOGIN_LOCK_MINUTES=15
# 可选：邮箱激活 token 分钟数。
AUTH_VERIFY_TOKEN_MINUTES=1440
# 可选：重置密码 token 分钟数。
AUTH_RESET_TOKEN_MINUTES=30
# 必填：前端对外访问地址，用于邮件链接与跨域配置。
AUTH_FRONTEND_BASE_URL=http://localhost:3000

# --------------------------------------------------------------------
# Email (optional)
# --------------------------------------------------------------------
# 可选：仅在 AUTH_REQUIRE_EMAIL_VERIFICATION=true 时必填。
SENDGRID_API_KEY=
# 可选：发件邮箱。
SENDGRID_FROM_EMAIL=

# --------------------------------------------------------------------
# Scheduler
# --------------------------------------------------------------------
# 可选：是否启用统一创作任务调度。
# 枚举：true | false
CREATION_SCHEDULER_ENABLED=true
# 可选：每用户默认并发任务数。
CREATION_DEFAULT_MAX_CONCURRENT_TASKS=1

# --------------------------------------------------------------------
# Logging
# --------------------------------------------------------------------
# 可选：日志格式。
# 枚举：json | text
LOG_FORMAT=json
# 可选：日志级别。
# 枚举：DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# 可选：API 慢请求阈值，单位毫秒。
LOG_SLOW_THRESHOLD_MS=1500
# 可选：LangGraph node 慢执行阈值，单位毫秒。
LOG_NODE_SLOW_THRESHOLD_MS=2500
# 可选：日志脱敏级别。
# 枚举：minimal | full
LOG_REDACTION_LEVEL=minimal
# 可选：日志目录。
LOG_DIR=log

# --------------------------------------------------------------------
# System settings (optional)
# --------------------------------------------------------------------
# 可选：配置后，管理员在系统设置里保存的 API Key 会加密存储。
SYSTEM_SETTINGS_MASTER_KEY=
