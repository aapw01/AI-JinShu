# Database
DATABASE_URL=postgresql://novel:novel_secret@localhost:5432/novel_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1

# ──────────────────────────────────────────────
# LLM Configuration (required)
# ──────────────────────────────────────────────
# 单一主模型配置：provider 只选一个，系统不支持多 Provider 回退链
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# 留空时走官方默认端点；只要填写自定义 Base URL，系统默认按 OpenAI 兼容协议处理
LLM_BASE_URL=
LLM_API_KEY=your-api-key-here
# 强制指定 LLM 通讯协议（可选，留空即为 auto 自动推断）
#   auto            — 有自定义 BASE_URL 时走 openai_compatible，否则走 provider 原生
#   openai_compatible — 始终用 OpenAI SDK（适配大多数网关如 new-api / one-api）
#   gemini          — 使用 Google Gemini 原生 SDK
#   anthropic       — 使用 Anthropic 原生 SDK
LLM_PROTOCOL_OVERRIDE=

# 单一向量模型配置
EMBEDDING_ENABLED=true
EMBEDDING_MODEL=text-embedding-3-small
# true: 复用主模型连接；仅当主模型是 OpenAI 兼容协议时可用
EMBEDDING_REUSE_PRIMARY_CONNECTION=true
# 仅在不复用主模型连接时填写；默认按 OpenAI 兼容协议处理
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=

# ──────────────────────────────────────────────
# Auth
# ──────────────────────────────────────────────
AUTH_JWT_SECRET=change-me-in-production-and-must-be-at-least-32-bytes
AUTH_JWT_ISSUER=ai-jinshu
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=
AUTH_REQUIRE_EMAIL_VERIFICATION=false
AUTH_LOGIN_MAX_FAILURES=5
AUTH_LOGIN_LOCK_MINUTES=15
AUTH_VERIFY_TOKEN_MINUTES=1440
AUTH_RESET_TOKEN_MINUTES=30
AUTH_FRONTEND_BASE_URL=http://localhost:3000

# SendGrid (optional, required only when AUTH_REQUIRE_EMAIL_VERIFICATION=true)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ──────────────────────────────────────────────
# Scheduler
# ──────────────────────────────────────────────
CREATION_SCHEDULER_ENABLED=true
CREATION_DEFAULT_MAX_CONCURRENT_TASKS=1

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
LOG_FORMAT=json
LOG_LEVEL=INFO

# ──────────────────────────────────────────────
# System settings (optional)
# ──────────────────────────────────────────────
# If configured, admin-saved API keys are encrypted before storing into DB.
SYSTEM_SETTINGS_MASTER_KEY=
