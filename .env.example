# Database
DATABASE_URL=postgresql://novel:novel_secret@localhost:5432/novel_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1

# LLM Provider Configuration
# Available providers: openai, anthropic, gemini
# Use one unified model/base_url/api_key set for the selected provider.
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here

# Auth
AUTH_JWT_SECRET=change-me-in-production-and-must-be-at-least-32-bytes
AUTH_JWT_ISSUER=ai-jinshu
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=
# 是否强制邮箱激活后才能登录。默认 false；若设为 true，必须配置 SendGrid。
AUTH_REQUIRE_EMAIL_VERIFICATION=false
AUTH_LOGIN_MAX_FAILURES=5
AUTH_LOGIN_LOCK_MINUTES=15
AUTH_VERIFY_TOKEN_MINUTES=1440
AUTH_RESET_TOKEN_MINUTES=30
AUTH_FRONTEND_BASE_URL=http://localhost:3000

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Quota
# 是否启用“并发生成上限”限制。默认 false（不限制并发创建）。
QUOTA_ENFORCE_CONCURRENCY_LIMIT=false
# Unified creation scheduler（Generation + Rewrite）
CREATION_SCHEDULER_ENABLED=true
CREATION_DEFAULT_MAX_CONCURRENT_TASKS=1
CREATION_DISPATCH_POLL_SECONDS=2
CREATION_MAX_DISPATCH_BATCH=5
CREATION_WORKER_LEASE_TTL_SECONDS=20
CREATION_WORKER_HEARTBEAT_SECONDS=5
CREATION_RECOVERY_POLL_SECONDS=5
# 月度限额（默认调高，避免开发/内测频繁触发）
QUOTA_FREE_MONTHLY_CHAPTER_LIMIT=1000000
QUOTA_FREE_MONTHLY_TOKEN_LIMIT=10000000000
QUOTA_ADMIN_MONTHLY_CHAPTER_LIMIT=10000000
QUOTA_ADMIN_MONTHLY_TOKEN_LIMIT=100000000000

# Logging
LOG_FORMAT=json
LOG_LEVEL=INFO
LOG_SLOW_THRESHOLD_MS=1500
LOG_NODE_SLOW_THRESHOLD_MS=2500
LOG_REDACTION_LEVEL=minimal
